@model Daftry.Models.Order
@{
    Layout = null; // إلغاء اللي آوت العام عشان تطلع الفاتورة لوحدها صافية للطباعة
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>فاتورة عميل</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />
    <style>
        body { font-family: 'Segoe UI', Tahoma, sans-serif; padding: 30px; }
        .invoice-header { border-bottom: 2px dashed #198754; padding-bottom: 15px; margin-bottom: 25px; }
    </style>
</head>
<body>
    <div class="container border p-4">
        <div class="invoice-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="text-success fw-bold">دفتري - فاتورة مبيعات</h2>
                <h5 class="mt-3">اسم العميل: <span class="text-primary">@Model.Customer.Name</span></h5>
            </div>
            <div class="text-end">
                <p class="mb-1"><strong>رقم الفاتورة:</strong> @Model.OrderSerialNumber</p>
                <p class="mb-0"><strong>التاريخ والوقت:</strong> @Model.OrderDate.ToString("yyyy-MM-dd hh:mm tt")</p>
            </div>
        </div>

        <table class="table table-bordered text-center my-4">
            <thead class="table-dark">
                <tr>
                    <th>المنتج</th>
                    <th>الكمية</th>
                    <th>سعر الوحدة</th>
                    <th>الإجمالي</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitPrice جنيه</td>
                        <td>@(item.Quantity * item.UnitPrice) جنيه</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="text-end mt-4">
            <h4>إجمالي الفاتورة الصافي: <span class="text-danger fw-bold">@Model.Items.Sum(x => x.Quantity * x.UnitPrice) جنيه</span></h4>
        </div>
    </div>
</body>
</html>