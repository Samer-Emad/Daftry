@model Daftry.ViewModels.CreateOrderVM

<div class="container mt-4 text-right" dir="rtl">
    <div class="card mb-4 bg-dark text-white">
        <div class="card-body">
            <h3>تسجيل فاتورة يدوي بالكامل (سحب على الدفتر) للعميل: <span class="text-warning">@Model.CustomerName</span></h3>
        </div>
    </div>
    
    <hr />

    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="CustomerId" />
        <input type="hidden" asp-for="CustomerName" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="text-secondary">اكتب المنتجات التي اشتراها العميل:</h5>
            <button type="button" id="addItemBtn" class="btn btn-info fw-bold">إضافة سطر منتج (+)</button>
        </div>
        
        <table class="table table-bordered text-center" id="invoiceTable">
            <thead class="table-primary">
                <tr>
                    <th>اسم المنتج (اكتب يدوي)</th>
                    <th style="width: 180px;">السعر (جنيه)</th>
                    <th style="width: 150px;">الكمية</th>
                    <th style="width: 100px;">حذف</th>
                </tr>
            </thead>
            <tbody id="invoiceBody">
            </tbody>
        </table>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold">حفظ الفاتورة في الدفتر</button>
            <a asp-controller="Customers" asp-action="Details" asp-route-id="@Model.CustomerId" class="btn btn-secondary btn-lg">إلغاء</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let itemIndex = 0;

        document.getElementById('addItemBtn').addEventListener('click', function () {
            const tbody = document.getElementById('invoiceBody');

            // بناء السطر الجديد بـ ٣ حقول إدخال فارغة تماماً (اسم، سعر، كمية)
            const rowHtml = `
                <tr id="row-${itemIndex}">
                    <td>
                        <input type="text" name="SelectedItems[${itemIndex}].ProductName" class="form-control" placeholder="مثال: جبنة، كيس أرز، شيبسي..." required />
                    </td>
                    <td>
                        <input type="number" name="SelectedItems[${itemIndex}].UnitPrice" class="form-control text-center" step="0.01" placeholder="0.00" min="0" required />
                    </td>
                    <td>
                        <input type="number" name="SelectedItems[${itemIndex}].Quantity" class="form-control text-center" min="1" value="1" required />
                    </td>
                    <td>
                        <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(${itemIndex})">حذف</button>
                    </td>
                </tr>
            `;

            tbody.insertAdjacentHTML('beforeend', rowHtml);
            itemIndex++;
        });

        function removeRow(index) {
            const row = document.getElementById(`row-${index}`);
            if (row) {
                row.remove();
            }
        }
    </script>
}