@model Daftry.Models.Customer

<div class="container mt-4 text-right" dir="rtl" style="max-width: 500px;">
    <h4>إنشاء ملف عميل جديد بالدفتر</h4>
    <hr />
    <form asp-action="Create" method="post">
        
        <div class="form-group mb-3">
            <label class="form-label fw-bold">اسم العميل<span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control" placeholder="ادخل الاسم الكامل" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        
        <div class="form-group mb-3">
            <label class="form-label fw-bold">رقم التليفون<span class="text-danger">*</span></label>
            <input asp-for="Phone" class="form-control" placeholder="ادخل رقم التليفون" required />
            <span asp-validation-for="Phone" class="text-danger small fw-bold"></span>
        </div>
        
        <button type="submit" class="btn btn-primary w-100 fw-bold">حفظ العميل الجديد</button>
    </form>
</div>