@model IEnumerable<Daftry.Models.Customer>

<div class="container mt-4 text-right" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>دفاتر العملاء - السوبر ماركت</h2>
        <a asp-action="Create" class="btn btn-success">إضافة عميل جديد (+)</a>
    </div>

    <table class="table table-bordered table-striped text-center">
        <thead class="table-dark">
            <tr>
                <th>الإسم</th>
                <th>رقم التليفون</th>
                <th>التحكم</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in Model)
            {
                <tr>
                    <td>@customer.Name</td>
                    <td>@customer.Phone</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@customer.Id" class="btn btn-info btn-sm">عرض الحساب والدفتر</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>