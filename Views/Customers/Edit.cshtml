@model Daftry.Models.Customer

<div class="container mt-4 text-right" dir="rtl">
    <div class="card mb-4 bg-dark text-white">
        <div class="card-body">
            <h3>تعديل بيانات العميل: <span class="text-warning">@Model.Name</span></h3>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">اسم العميل الثنائي/الثلاثي:</label>
                    <input asp-for="Name" class="form-control form-control-lg" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Phone" class="form-label fw-bold">رقم العميل مطلوب:</label>
                    <input asp-for="Phone" class="form-control form-control-lg" required />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success btn-lg px-5 fw-bold">حفظ التغييرات</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary btn-lg">إلغاء والعودة للدفتر</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}